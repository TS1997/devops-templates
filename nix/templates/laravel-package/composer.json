{
    "name": "{{vendor_slug}}/{{package_slug}}",
    "description": "{{package_description}}",
    "keywords": [
        "{{vendor_slug}}",
        "laravel",
        "{{package_slug}}"
    ],
    "homepage": "https://github.com/{{vendor_slug}}/{{package_slug}}",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "ts1997/laravel-package-dev-tools": "^1.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "{{vendor_namespace}}\\Skeleton\\": "src/",
            "{{vendor_namespace}}\\Skeleton\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "{{vendor_namespace}}\\Skeleton\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "post-install-cmd": [
            "@php vendor/bin/testbench vendor:publish --tag=package-dev-tools-artisan --ansi --force",
            "@php vendor/bin/testbench boost:update --ansi --discover"
        ],
        "post-update-cmd": [
            "@php vendor/bin/testbench vendor:publish --tag=package-dev-tools-artisan --ansi --force",
            "@php vendor/bin/testbench boost:update --ansi --discover"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "{{vendor_namespace}}\\Skeleton\\SkeletonServiceProvider"
            ],
            "aliases": {
                "Skeleton": "{{vendor_namespace}}\\Skeleton\\Facades\\Skeleton"
            }
        },
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ],
            "merge-extra": true,
            "merge-extra-deep": true,
            "recurse": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.ts1997.com"
        }
    ]
}
